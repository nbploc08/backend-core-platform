SERVICE_NAME=auth-service
PORT=3001
LOG_LEVEL=info

# Database (Prisma)
DATABASE_URL="postgresql://core:corepass@localhost:5433/coredb?schema=auth"

# NATS JetStream
NATS_URL=nats://localhost:4222

# JWT (cùng giá trị với gateway nếu verify token qua gateway)
JWT_SECRET=your-jwt-secret-change-in-production
JWT_ISSUER=auth-service
JWT_AUDIENCE=api
JWT_EXPIRES_IN=900
JWT_REFRESH_EXPIRES_IN=2592000

# Same value as notification-service (for OTP code encrypt/decrypt)
ENCRYPT_KEY=your-secret-key-min-16-chars

# Internal JWT (service-to-service) — same values as gateway
INTERNAL_JWT_SECRET=your-internal-jwt-secret-change-in-production
INTERNAL_JWT_ISSUER=gateway
INTERNAL_JWT_AUDIENCE=internal

# Redis (rate limiter + permission cache + BullMQ)
REDIS_URL=redis://localhost:6379
