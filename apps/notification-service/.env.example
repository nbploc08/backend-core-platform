SERVICE_NAME=notification-service
PORT=3002
LOG_LEVEL=info

# Database (Prisma)
DATABASE_URL="postgresql://core:corepass@localhost:5433/coredb?schema=notification"

# NATS JetStream
NATS_URL=nats://localhost:4222

# Mail (Gmail SMTP — use App Password)
MAIL_USER=your-email@gmail.com
MAIL_APP_PASSWORD=your-app-password

# Base URL for email verify link (auth-service URL)
VERIFY_LINK_BASE_URL=http://localhost:3001

# Same value as auth-service (for OTP code decrypt)
ENCRYPT_KEY=your-secret-key-min-16-chars

# JWT (for verifying user tokens in internal endpoints)
JWT_SECRET=your-jwt-secret-change-in-production
JWT_ISSUER=auth-service
JWT_AUDIENCE=api

# Internal JWT (service-to-service)
INTERNAL_JWT_SECRET=your-internal-jwt-secret-change-in-production
INTERNAL_JWT_ISSUER=gateway
INTERNAL_JWT_AUDIENCE=internal

# Redis (BullMQ job queue + permission cache)
REDIS_URL=redis://localhost:6379

# Auth-service URL (for RBAC permission fetching)
AUTH_SERVICE_URL=http://localhost:3001
